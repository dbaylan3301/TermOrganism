#!/usr/bin/env python3
from __future__ import annotations
import time

import json
import os
import socket
import subprocess
import sys
from pathlib import Path


# --- daemon autostart helpers ---
DAEMON_SOCKET = "/tmp/termorganism.sock"
REPO_ROOT = Path(__file__).resolve().parent


def _get_daemon_socket_path() -> str:
    return os.environ.get("TERMORGANISM_DAEMON_SOCKET", DAEMON_SOCKET)


def _wait_for_unix_socket(path: str, timeout: float = 8.0, interval: float = 0.1) -> bool:
    deadline = time.time() + timeout
    while time.time() < deadline:
        if os.path.exists(path):
            try:
                client = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
                client.settimeout(0.2)
                client.connect(path)
                client.close()
                return True
            except OSError:
                pass
        time.sleep(interval)
    return False


def _start_daemon_if_needed() -> bool:
    sock_path = _get_daemon_socket_path()

    if _wait_for_unix_socket(sock_path, timeout=0.25, interval=0.05):
        return True

    try:
        if os.path.exists(sock_path):
            os.unlink(sock_path)
    except OSError:
        pass

    log_path = "/tmp/termorganism-daemon.log"
    with open(log_path, "ab") as logf:
        subprocess.Popen(
            [sys.executable, "-m", "core.daemon.server"],
            cwd=str(REPO_ROOT),
            stdout=logf,
            stderr=logf,
            stdin=subprocess.DEVNULL,
            start_new_session=True,
        )

    return _wait_for_unix_socket(sock_path, timeout=8.0, interval=0.1)


def _truthy(value: str | None) -> bool:
    return str(value or "").strip().lower() in {"1", "true", "yes", "on"}


def _usage() -> int:
    print(json.dumps({
        "success": False,
        "error": (
            "Usage: ./termorganism repair <file> [--json] [--fast] "
            "[--git-branch] [--git-undo] [--git-commit] "
            "[--git-branch-name=name] [--git-commit-message=msg] | "
            "./termorganism undo <file-or-path> --undo-ref=<ref> | "
            "./termorganism plugins list|enable <name>|disable <name>"
        )
    }))
    return 1


def _mode_from_env(argv: list[str]) -> str:
    if _truthy(os.getenv("TERMORGANISM_HOT_FORCE")):
        return "hot_force"
    if _truthy(os.getenv("TERMORGANISM_FAST_V2")):
        return "fast_v2"
    if "--fast" in argv:
        return "fast"
    return "auto"


def _socket_path() -> str:
    return os.getenv("TERMORGANISM_SOCKET", "/tmp/termorganism.sock")


def _client_timeout() -> float:
    try:
        return float(os.getenv("TERMORGANISM_CLIENT_TIMEOUT", "5"))
    except Exception:
        return 5.0


def _send_to_daemon(payload: dict, socket_path: str) -> dict:
    def _send_once() -> dict:
        sock_path = _get_daemon_socket_path()
        client = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        client.connect(sock_path)
        client.sendall(json.dumps(payload).encode("utf-8"))
        client.shutdown(socket.SHUT_WR)

        chunks = []
        while True:
            part = client.recv(65536)
            if not part:
                break
            chunks.append(part)
        client.close()

        buf = b"".join(chunks)
        return json.loads(buf.decode("utf-8"))

    try:
        return _send_once()
    except (FileNotFoundError, ConnectionRefusedError, OSError):
        if not _start_daemon_if_needed():
            return {
                "success": False,
                "mode": "python_cli",
                "error": f"daemon socket not found and auto-start failed: {_get_daemon_socket_path()}",
                "log": "/tmp/termorganism-daemon.log",
            }
        return _send_once()
def _daemon_available() -> bool:
    return Path(_socket_path()).exists()


def _run_plugins(argv: list[str]) -> int:
    proc = subprocess.run(
        [sys.executable, "-m", "core.plugins.cli", *argv[2:]],
        text=True,
    )
    return proc.returncode


def _extract_flag_value(argv: list[str], prefix: str) -> str:
    for arg in argv:
        if arg.startswith(prefix):
            return arg.split("=", 1)[1]
    return ""


def _build_repair_payload(argv: list[str], target: str, mode: str) -> dict:
    payload = {
        "command": "repair",
        "file": target,
        "mode": mode,
        "context": {
            "file": target,
            "hint": "python_cli",
        },
    }

    if "--git-branch" in argv:
        payload["git_branch"] = True
    if "--git-undo" in argv:
        payload["git_undo"] = True
    if "--git-commit" in argv:
        payload["git_commit"] = True

    branch_name = _extract_flag_value(argv, "--git-branch-name=")
    if branch_name:
        payload["git_branch_name"] = branch_name

    commit_message = _extract_flag_value(argv, "--git-commit-message=")
    if commit_message:
        payload["git_commit_message"] = commit_message

    return payload


def _run_undo(argv: list[str]) -> int:
    if len(argv) < 3:
        return _usage()

    target = argv[2]
    undo_ref = _extract_flag_value(argv, "--undo-ref=")
    if not undo_ref:
        print(json.dumps({"success": False, "error": "missing --undo-ref=<ref>"}))
        return 1

    if not _daemon_available() and not _start_daemon_if_needed():
        print(json.dumps({"success": False, "mode": "python_cli", "error": f"daemon socket not found and auto-start failed: {_get_daemon_socket_path()}", "log": "/tmp/termorganism-daemon.log"}))
        return 1

    result = _send_to_daemon(
        {
            "command": "undo",
            "file": target,
            "undo_ref": undo_ref,
        },
        socket_path=_socket_path(),
    )
    print(json.dumps(result, ensure_ascii=False))
    return 0 if result.get("success") else 1


def _run_repair(argv: list[str]) -> int:
    if len(argv) < 3:
        return _usage()

    target = argv[2]
    if not Path(target).exists():
        print(json.dumps({"success": False, "mode": "python_cli", "error": f"target does not exist: {target}"}))
        return 1

    if not _daemon_available() and not _start_daemon_if_needed():
        print(json.dumps({"success": False, "mode": "python_cli", "error": f"daemon socket not found and auto-start failed: {_get_daemon_socket_path()}", "log": "/tmp/termorganism-daemon.log"}))
        return 1

    mode = _mode_from_env(argv)
    payload = _build_repair_payload(argv, target, mode)
    result = _send_to_daemon(payload, socket_path=_socket_path())
    print(json.dumps(result, ensure_ascii=False))
    return 0 if result.get("success") else 1


def main() -> int:
    argv = sys.argv
    if len(argv) < 2:
        return _usage()

    cmd = argv[1]

    if cmd == "plugins":
        return _run_plugins(argv)
    if cmd == "undo":
        return _run_undo(argv)
    if cmd == "repair":
        return _run_repair(argv)

    return _usage()


if __name__ == "__main__":
    raise SystemExit(main())
