#!/usr/bin/env python3
import json
import os
import socket
import sys
from pathlib import Path
import re


def _json_requested(argv):
    return "--json" in argv


def _target_from_argv(argv):
    if len(argv) >= 3 and argv[1] == "repair":
        return argv[2]
    return None


def _mode_from_env(argv):
    if os.getenv("TERMORGANISM_HOT_FORCE", "").strip().lower() in {"1", "true", "yes", "on"}:
        return "hot_force"
    if "--fast" in argv:
        return "fast"
    return "auto"


def _minimal_context(file_path: str) -> dict:
    p = Path(file_path)
    if not p.exists():
        return {"error": "file_not_found", "file": file_path}

    try:
        with p.open("r", encoding="utf-8", errors="ignore") as f:
            content = f.read(4096)
    except Exception as e:
        return {"error_type": type(e).__name__, "file": file_path}

    if "open(" in content and ".read()" in content:
        return {"file": file_path, "hint": "filenotfounderror", "signature": "filenotfounderror:open:runtime"}

    if "read_text(" in content:
        return {"file": file_path, "hint": "filenotfounderror", "signature": "filenotfounderror:open:runtime"}

    if re.search(r'(?m)^\s*import\s+[A-Za-z_][A-Za-z0-9_]*(?:\s+as\s+[A-Za-z_][A-Za-z0-9_]*)?\s*$', content):
        return {"file": file_path, "hint": "importerror", "signature": "importerror:no_module_named"}

    if re.search(r'(?m)^\s*from\s+[A-Za-z_][A-Za-z0-9_\.]*\s+import\s+[A-Za-z_][A-Za-z0-9_]*\s*$', content):
        return {"file": file_path, "hint": "importerror", "signature": "importerror:no_module_named"}

    return {"file": file_path, "hint": "unknown"}


def _send_to_daemon(payload: dict, socket_path: str = "/tmp/termorganism.sock") -> dict:
    sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    timeout_sec = float(os.getenv("TERMORGANISM_CLIENT_TIMEOUT", "30"))
    sock.settimeout(timeout_sec)
    try:
        sock.connect(socket_path)
        sock.sendall(json.dumps(payload).encode("utf-8"))
        sock.shutdown(socket.SHUT_WR)

        response = b""
        while True:
            chunk = sock.recv(65536)
            if not chunk:
                break
            response += chunk

        if not response:
            return {"success": False, "error": "empty daemon response", "mode": "daemon_client"}

        return json.loads(response.decode("utf-8"))
    finally:
        sock.close()


def _daemon_available(socket_path: Path) -> bool:
    return socket_path.exists() and os.getenv("TERMORGANISM_USE_DAEMON", "1") == "1"


def _exit_code_from_result(result: dict) -> int:
    if bool(result.get("success")):
        return 0
    if bool((result.get("verify") or {}).get("ok")):
        return 0
    return 1


def _run_daemon(argv) -> int | None:
    socket_path = Path("/tmp/termorganism.sock")
    if not _daemon_available(socket_path):
        return None

    target = _target_from_argv(argv)
    if not target:
        return None

    mode = _mode_from_env(argv)
    context = _minimal_context(target)

    if mode == "hot_force" and context.get("signature"):
        payload = {
            "fast_path": "hot_force",
            "file": target,
            "signature": context["signature"],
            "mode": "hot_force",
        }
    else:
        payload = {
            "file": target,
            "context": context,
            "mode": mode,
        }

    result = _send_to_daemon(payload, socket_path=str(socket_path))

    if "--json" in argv:
        print(json.dumps(result, indent=2, ensure_ascii=False))
    else:
        print(json.dumps(result, ensure_ascii=False))

    return _exit_code_from_result(result)


def main():
    daemon_rc = _run_daemon(sys.argv)
    if daemon_rc is not None:
        return daemon_rc

    from core.cli.autofix_cli import main as slow_main
    return slow_main()


if __name__ == "__main__":
    raise SystemExit(main())
