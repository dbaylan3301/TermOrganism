#!/usr/bin/env python3
from __future__ import annotations

import json
import os
import socket
import subprocess
import sys
from pathlib import Path


def _truthy(value: str | None) -> bool:
    return str(value or "").strip().lower() in {"1", "true", "yes", "on"}


def _usage() -> int:
    print(json.dumps({
        "success": False,
        "error": (
            "Usage: ./termorganism repair <file> [--json] [--fast] "
            "[--git-branch] [--git-undo] [--git-commit] "
            "[--git-branch-name=name] [--git-commit-message=msg] | "
            "./termorganism undo <file-or-path> --undo-ref=<ref> | "
            "./termorganism plugins list|enable <name>|disable <name>"
        )
    }))
    return 1


def _mode_from_env(argv: list[str]) -> str:
    if _truthy(os.getenv("TERMORGANISM_HOT_FORCE")):
        return "hot_force"
    if _truthy(os.getenv("TERMORGANISM_FAST_V2")):
        return "fast_v2"
    if "--fast" in argv:
        return "fast"
    return "auto"


def _socket_path() -> str:
    return os.getenv("TERMORGANISM_SOCKET", "/tmp/termorganism.sock")


def _client_timeout() -> float:
    try:
        return float(os.getenv("TERMORGANISM_CLIENT_TIMEOUT", "5"))
    except Exception:
        return 5.0


def _send_to_daemon(payload: dict, socket_path: str) -> dict:
    sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    sock.settimeout(_client_timeout())
    try:
        sock.connect(socket_path)
        sock.sendall(json.dumps(payload).encode("utf-8"))
        sock.shutdown(socket.SHUT_WR)
        buf = b""
        while True:
            chunk = sock.recv(65536)
            if not chunk:
                break
            buf += chunk
    finally:
        sock.close()

    if not buf:
        return {"success": False, "error": "empty daemon response"}
    return json.loads(buf.decode("utf-8"))


def _daemon_available() -> bool:
    return Path(_socket_path()).exists()


def _run_plugins(argv: list[str]) -> int:
    proc = subprocess.run(
        [sys.executable, "-m", "core.plugins.cli", *argv[2:]],
        text=True,
    )
    return proc.returncode


def _extract_flag_value(argv: list[str], prefix: str) -> str:
    for arg in argv:
        if arg.startswith(prefix):
            return arg.split("=", 1)[1]
    return ""


def _build_repair_payload(argv: list[str], target: str, mode: str) -> dict:
    payload = {
        "command": "repair",
        "file": target,
        "mode": mode,
        "context": {
            "file": target,
            "hint": "python_cli",
        },
    }

    if "--git-branch" in argv:
        payload["git_branch"] = True
    if "--git-undo" in argv:
        payload["git_undo"] = True
    if "--git-commit" in argv:
        payload["git_commit"] = True

    branch_name = _extract_flag_value(argv, "--git-branch-name=")
    if branch_name:
        payload["git_branch_name"] = branch_name

    commit_message = _extract_flag_value(argv, "--git-commit-message=")
    if commit_message:
        payload["git_commit_message"] = commit_message

    return payload


def _run_undo(argv: list[str]) -> int:
    if len(argv) < 3:
        return _usage()

    target = argv[2]
    undo_ref = _extract_flag_value(argv, "--undo-ref=")
    if not undo_ref:
        print(json.dumps({"success": False, "error": "missing --undo-ref=<ref>"}))
        return 1

    if not _daemon_available():
        print(json.dumps({"success": False, "mode": "python_cli", "error": f"daemon socket not found: {_socket_path()}"}))
        return 1

    result = _send_to_daemon(
        {
            "command": "undo",
            "file": target,
            "undo_ref": undo_ref,
        },
        socket_path=_socket_path(),
    )
    print(json.dumps(result, ensure_ascii=False))
    return 0 if result.get("success") else 1


def _run_repair(argv: list[str]) -> int:
    if len(argv) < 3:
        return _usage()

    target = argv[2]
    if not Path(target).exists():
        print(json.dumps({"success": False, "mode": "python_cli", "error": f"target does not exist: {target}"}))
        return 1

    if not _daemon_available():
        print(json.dumps({"success": False, "mode": "python_cli", "error": f"daemon socket not found: {_socket_path()}"}))
        return 1

    mode = _mode_from_env(argv)
    payload = _build_repair_payload(argv, target, mode)
    result = _send_to_daemon(payload, socket_path=_socket_path())
    print(json.dumps(result, ensure_ascii=False))
    return 0 if result.get("success") else 1


def main() -> int:
    argv = sys.argv
    if len(argv) < 2:
        return _usage()

    cmd = argv[1]

    if cmd == "plugins":
        return _run_plugins(argv)
    if cmd == "undo":
        return _run_undo(argv)
    if cmd == "repair":
        return _run_repair(argv)

    return _usage()


if __name__ == "__main__":
    raise SystemExit(main())
